<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MfPda" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="MfToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/text_white</item>
        <item name="subtitleTextColor">@color/text_white</item>
        <item name="navigationIconTint">@color/text_white</item>
    </style>

    <style name="MfButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">6dp</item>
    </style>
    <style name="MfButton.Red" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/btn_red</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">6dp</item>
    </style>
    <style name="MfButton.Green" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/btn_green</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">6dp</item>
    </style>
    <style name="MfButton.Blue" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/btn_blue</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">6dp</item>
    </style>
    <style name="MfButton.Warn" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/btn_warn</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">6dp</item>
    </style>

    <style name="MfText" />
    <style name="MfText.Red">
        <item name="android:textColor">@color/text_red</item>
    </style>
    <style name="MfText.Code" parent="MfText.Red">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MfTab" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorColor">@color/text_red</item>
        <item name="tabSelectedTextColor">@color/text_red</item>
        <item name="tabTextColor">@color/text_hint</item>
    </style>

    <style name="MfListRow">
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>
</resources>
