<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <!-- 顶部表单：日期、备注 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/oc_date_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/et_underline"
                android:gravity="center_vertical"
                android:minHeight="32dp"
                android:padding="6dp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/bg_line" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/oc_remark_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <EditText
                android:id="@+id/et_remark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/et_underline"
                android:gravity="center_vertical"
                android:hint="@string/rc_remark_hint"
                android:minHeight="32dp"
                android:padding="6dp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </LinearLayout>

    <!-- 条码列表（独立滚动） -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:nestedScrollingEnabled="false" />

    <!-- 底部固定：输入+按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_code"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/et_underline"
                android:hint="@string/oc_input_hint"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:padding="6dp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <Button
                android:id="@+id/btn_scan"
                style="@style/MfButton.Primary"
                android:layout_width="68dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/oc_btn_scan"
                android:textSize="@dimen/text_small" />

            <Button
                android:id="@+id/btn_confirm"
                style="@style/MfButton.Green"
                android:layout_width="68dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/oc_btn_confirm"
                android:textSize="@dimen/text_small" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_save"
            style="@style/MfButton.Green"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:layout_marginTop="8dp"
            android:text="@string/oc_btn_save" />
    </LinearLayout>
</LinearLayout>
