<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/tv_cust_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_cust"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/oc_cust_default"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/oc_date_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/et_underline"
                    android:minHeight="32dp"
                    android:padding="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rg_billtype"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <RadioButton
                    android:id="@+id/rb_ckd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/oc_billtype_ckd" />

                <RadioButton
                    android:id="@+id/rb_tkd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/oc_billtype_tkd" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/oc_remark_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

                <EditText
                    android:id="@+id/et_remark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/oc_remark_hint"
                    android:minHeight="32dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <EditText
                    android:id="@+id/et_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/oc_input_hint"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:minHeight="40dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="@dimen/text_body" />

                <Button
                    android:id="@+id/btn_scan"
                    style="@style/MfButton.Green"
                    android:layout_width="60dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="@string/oc_btn_scan"
                    android:textSize="@dimen/text_small" />

                <Button
                    android:id="@+id/btn_confirm_or_cancel"
                    style="@style/MfButton.Green"
                    android:layout_width="60dp"
                    android:layout_height="32dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="@string/cancel"
                    android:textSize="@dimen/text_small" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_save"
                style="@style/MfButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:text="@string/oc_btn_save" />

            <Button
                android:id="@+id/btn_paste"
                style="@style/MfButton.Blue"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:text="@string/oc_btn_paste" />

            <Button
                android:id="@+id/btn_faststock"
                style="@style/MfButton.Red"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:text="@string/oc_btn_faststock"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
