<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <!-- 顶部表单区域：卡片边框 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_form_card"
        android:orientation="vertical"
        android:layout_margin="8dp">

        <LinearLayout
            android:id="@+id/tv_cust_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/oc_cust_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tv_cust"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:gravity="end"
                android:text="@string/oc_cust_default"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="&#9654;"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="4dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/oc_date_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:gravity="end"
                android:background="@null"
                android:minHeight="32dp"
                android:padding="6dp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rg_billtype"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp">

            <RadioButton
                android:id="@+id/rb_ckd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/oc_billtype_ckd" />

            <RadioButton
                android:id="@+id/rb_tkd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/oc_billtype_tkd" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="4dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/oc_remark_label"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <EditText
                android:id="@+id/et_remark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:gravity="end"
                android:background="@null"
                android:hint="@string/oc_remark_hint"
                android:minHeight="32dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />
        </LinearLayout>
    </LinearLayout>

    <!-- 中间产品列表：独立滚动，尽量大 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:overScrollMode="never" />

    <!-- 底部按钮区域：紧凑排列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp">

        <EditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_border"
            android:hint="@string/oc_input_hint"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:minHeight="36dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="@dimen/text_body" />

        <Button
            android:id="@+id/btn_scan"
            style="@style/MfButton.Green"
            android:layout_width="68dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="@string/oc_btn_scan"
            android:textSize="@dimen/text_small" />

        <Button
            android:id="@+id/btn_confirm_or_cancel"
            style="@style/MfButton.Green"
            android:layout_width="68dp"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="@string/oc_btn_light_on"
            android:textSize="@dimen/text_small" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_save"
        style="@style/MfButton.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="16dp"
        android:text="@string/oc_btn_save" />

    <Button
        android:id="@+id/btn_paste"
        style="@style/MfButton.Blue"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="16dp"
        android:text="@string/oc_btn_paste" />

    <Button
        android:id="@+id/btn_faststock"
        style="@style/MfButton.Red"
        android:layout_width="match_parent"
        android:layout_height="@dimen/btn_height"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="6dp"
        android:text="@string/oc_btn_faststock"
        android:visibility="gone" />
</LinearLayout>
